---
import '../styles/tokens.css';
import '../styles/global.css';
import { localeCodes, localePath } from '../content/locales';
import type { MarketingContent } from '../content/types';
import tokens from '../design/tokens.json';
import { SITE_URL } from '../config';

interface Props {
  content: MarketingContent;
  canonicalPath: string;
  title?: string;
  description?: string;
  noindex?: boolean;
  productSchema?: boolean;
  alternateLinks?: Array<{ locale: string; path: string }>;
  xDefaultPath?: string;
}

const {
  content,
  canonicalPath,
  title = `${content.seo.title} | DiscVault`,
  description = content.seo.description,
  noindex = false,
  productSchema = true,
  alternateLinks = localeCodes.map((locale) => ({
    locale,
    path: localePath(locale),
  })),
  xDefaultPath = '/',
} = Astro.props;
const canonical = new URL(canonicalPath, SITE_URL).href;
const ogImage = new URL('/brand/discvault-icon-512-dark.png', SITE_URL).href;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': ['SoftwareApplication', 'Product'],
  '@id': `${SITE_URL}/#product`,
  name: 'DiscVault',
  description,
  url: canonical,
  image: ogImage,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS, iPadOS, Web',
  brand: {
    '@type': 'Brand',
    name: 'DiscVault',
  },
};
---

<!doctype html>
<html lang={content.locale} data-accent="bluray">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta
      name="theme-color"
      content={tokens.pwa['theme-color-dark'].$value}
      media="(prefers-color-scheme: dark)"
    />
    <meta
      name="theme-color"
      content={tokens.pwa['theme-color-light'].$value}
      media="(prefers-color-scheme: light)"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    {
      alternateLinks.map(({ locale, path }) => (
        <link
          rel="alternate"
          hreflang={locale}
          href={new URL(path, SITE_URL).href}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(xDefaultPath, SITE_URL).href}
    />
    <link
      rel="icon"
      type="image/png"
      href="/brand/discvault-icon-512-dark.png"
    />
    <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DiscVault" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:locale" content={content.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {
      productSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(structuredData)}
        />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>
