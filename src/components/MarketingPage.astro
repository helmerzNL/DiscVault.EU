---
import { Picture } from 'astro:assets';
import mobileLibrary from '../assets/showcase/mobile-library.png';
import mobileAdd from '../assets/showcase/mobile-import.png';
import mobileDetail from '../assets/showcase/mobile-detail.png';
import desktopLibrary from '../assets/showcase/desktop-library.png';
import desktopDetail from '../assets/showcase/desktop-detail.png';
import type { Locale } from '../content/locales';
import type { MarketingContent, ProductRoute } from '../content/types';
import {
  DISCORD_URL,
  DOCS_URL,
  ISSUES_URL,
  SUPPORT_URL,
  TESTFLIGHT_URL,
} from '../config';
import Footer from './Footer.astro';
import Header from './Header.astro';

interface Props {
  content: MarketingContent;
  locale: Locale;
  homePath: string;
}

const { content, locale, homePath } = Astro.props;
const privacyPath = locale === 'nl' ? '/privacy-nl.html' : '/privacy.html';

const routes: Array<{
  id: string;
  route: ProductRoute;
  badge: string;
  href: string;
  cta: string;
}> = [
  {
    id: 'ios',
    route: content.routes.ios,
    badge: 'iOS / iPadOS',
    href: TESTFLIGHT_URL,
    cta: content.hero.testflight,
  },
  {
    id: 'self-hosted',
    route: content.routes.selfHosted,
    badge: 'PWA / Desktop',
    href: DOCS_URL,
    cta: content.hero.selfHosted,
  },
];
---

<Header content={content} locale={locale} homePath={homePath} />

<main id="main">
  <span id="discvault26" class="anchor-target" aria-hidden="true"></span>
  <section class="hero wrap">
    <div class="hero-copy">
      <p class="eyebrow">{content.hero.eyebrow}</p>
      <h1>
        {content.hero.title}
        <span>{content.hero.accent}</span>
      </h1>
      <p class="lead">{content.hero.lead}</p>
      <div class="dual-actions" aria-label={content.routes.heading}>
        <a class="button" href={TESTFLIGHT_URL}>
          <span class="button-kicker">iPhone & iPad</span>
          {content.hero.testflight}
        </a>
        <a class="button" href={DOCS_URL}>
          <span class="button-kicker">PWA & Desktop</span>
          {content.hero.selfHosted}
        </a>
      </div>
    </div>
    <div class="hero-mark" aria-hidden="true">
      <img
        src="/brand/discvault-logo-transparent.png"
        width="392"
        height="392"
        alt=""
        fetchpriority="high"
      />
    </div>
  </section>

  <span id="install" class="anchor-target" aria-hidden="true"></span>
  <section id="product" class="section wrap">
    <div class="section-heading">
      <p class="eyebrow">{content.routes.eyebrow}</p>
      <h2>{content.routes.heading}</h2>
    </div>
    <div class="route-grid">
      {
        routes.map(({ id, route, badge, href, cta }) => (
          <article id={id} class="route-card">
            {id === 'self-hosted' && (
              <span id="migration" class="anchor-target" aria-hidden="true" />
            )}
            <span class="platform-badge">{badge}</span>
            <p class="route-label">{route.label}</p>
            <h3>{route.title}</h3>
            <p>{route.body}</p>
            <ul>
              {route.points.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
            <a class="button" href={href}>
              {cta}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section section-tinted">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">{content.capabilities.eyebrow}</p>
        <h2>{content.capabilities.heading}</h2>
      </div>
      <div class="capability-grid">
        {
          content.capabilities.items.map((capability, index) => (
            <article class="capability-card">
              <span aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </span>
              <h3>{capability.title}</h3>
              <p>{capability.body}</p>
              <a href={DOCS_URL}>
                Docs <span aria-hidden="true">↗</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section wrap" aria-labelledby="showcase-title">
    <div class="section-heading">
      <p class="eyebrow">{content.showcase.eyebrow}</p>
      <h2 id="showcase-title">{content.showcase.heading}</h2>
    </div>
    <div class="showcase-grid">
      <figure class="shot shot-phone">
        <Picture
          src={mobileLibrary}
          formats={['avif']}
          fallbackFormat="webp"
          widths={[360, 540, 735]}
          sizes="(min-width: 900px) 24vw, 70vw"
          alt={content.showcase.mobileLibrary}
          loading="lazy"
        />
        <figcaption>{content.showcase.mobileLibrary}</figcaption>
      </figure>
      <figure class="shot shot-phone">
        <Picture
          src={mobileAdd}
          formats={['avif']}
          fallbackFormat="webp"
          widths={[360, 540, 735]}
          sizes="(min-width: 900px) 24vw, 70vw"
          alt={content.showcase.mobileAdd}
          loading="lazy"
        />
        <figcaption>{content.showcase.mobileAdd}</figcaption>
      </figure>
      <figure class="shot shot-phone">
        <Picture
          src={mobileDetail}
          formats={['avif']}
          fallbackFormat="webp"
          widths={[360, 540, 735]}
          sizes="(min-width: 900px) 24vw, 70vw"
          alt={content.showcase.mobileDetail}
          loading="lazy"
        />
        <figcaption>{content.showcase.mobileDetail}</figcaption>
      </figure>
      <figure class="shot shot-desktop">
        <Picture
          src={desktopLibrary}
          formats={['avif']}
          fallbackFormat="webp"
          widths={[640, 960, 1400]}
          sizes="(min-width: 900px) 52vw, 92vw"
          alt={content.showcase.desktopLibrary}
          loading="lazy"
        />
        <figcaption>{content.showcase.desktopLibrary}</figcaption>
      </figure>
      <figure class="shot shot-desktop">
        <Picture
          src={desktopDetail}
          formats={['avif']}
          fallbackFormat="webp"
          widths={[640, 960, 1400]}
          sizes="(min-width: 900px) 52vw, 92vw"
          alt={content.showcase.desktopDetail}
          loading="lazy"
        />
        <figcaption>{content.showcase.desktopDetail}</figcaption>
      </figure>
    </div>
  </section>

  <section id="privacy" class="section wrap">
    <div class="trust-panel">
      <div>
        <p class="eyebrow">{content.trust.eyebrow}</p>
        <h2>{content.trust.heading}</h2>
        <p class="lead">{content.trust.body}</p>
        <a class="text-link" href={privacyPath}>
          {content.footer.privacy}
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="trust-points">
        <article>
          <span aria-hidden="true">◎</span>
          <h3>{content.trust.noTrackingTitle}</h3>
          <p>{content.trust.noTrackingBody}</p>
        </article>
        <article>
          <span aria-hidden="true">◇</span>
          <h3>{content.trust.controlTitle}</h3>
          <p>{content.trust.controlBody}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-tinted">
    <div class="wrap comparison">
      <div class="section-heading">
        <p class="eyebrow">{content.comparison.eyebrow}</p>
        <h2>{content.comparison.heading}</h2>
      </div>
      <div
        class="table-scroll"
        tabindex="0"
        aria-label={content.comparison.heading}
      >
        <table>
          <thead>
            <tr>
              <th scope="col">{content.comparison.route}</th>
              <th scope="col">{content.comparison.bestFor}</th>
              <th scope="col">{content.comparison.setup}</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th scope="row">iPhone & iPad</th>
              <td>{content.comparison.iosBest}</td>
              <td>{content.comparison.iosSetup}</td>
            </tr>
            <tr>
              <th scope="row">Self-hosted</th>
              <td>{content.comparison.selfBest}</td>
              <td>{content.comparison.selfSetup}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section wrap community">
    <div>
      <p class="eyebrow">{content.community.eyebrow}</p>
      <h2>{content.community.heading}</h2>
    </div>
    <nav aria-label={content.community.heading}>
      <a class="chip-link" href={DISCORD_URL}>{content.community.discord}</a>
      <a class="chip-link" href={ISSUES_URL}>{content.community.issues}</a>
      <a class="chip-link" href={SUPPORT_URL}>{content.community.support}</a>
    </nav>
  </section>

  <section class="final-cta wrap">
    <p class="eyebrow">DiscVault</p>
    <h2>{content.community.finalTitle}</h2>
    <div class="dual-actions">
      <a class="button" href={TESTFLIGHT_URL}>
        <span class="button-kicker">iPhone & iPad</span>
        {content.hero.testflight}
      </a>
      <a class="button" href={DOCS_URL}>
        <span class="button-kicker">PWA & Desktop</span>
        {content.hero.selfHosted}
      </a>
    </div>
  </section>
</main>

<Footer content={content} locale={locale} />
