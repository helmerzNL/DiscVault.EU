{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$name": "DiscVault \u2014 Chrome & Blue",
  "$version": "3.1.0",
  "$description": "Dark-first colour system for DiscVault, keyed to the app icon. Background, accent and sheen are sampled directly from AppIcon-1024.png so the PWA splash, status bar and home-screen icon are one continuous surface. Only the accent group is user-swappable; neutrals, semantics and format badges are fixed.",
  "theme": {
    "dark": {
      "bg": {
        "$value": "#090F1A",
        "$type": "color",
        "$description": "App background \u2014 sampled from the app icon, so the icon bleeds into the splash screen"
      },
      "surface-1": {
        "$value": "#111A2A",
        "$type": "color",
        "$description": "Cards, sheets, nav bars"
      },
      "surface-2": {
        "$value": "#1A2438",
        "$type": "color",
        "$description": "Inputs, raised rows"
      },
      "surface-3": {
        "$value": "#243047",
        "$type": "color",
        "$description": "Hover/selected rows"
      },
      "border-subtle": {
        "$value": "#2B3852",
        "$type": "color",
        "$description": "Hairlines, dividers"
      },
      "border": {
        "$value": "#394863",
        "$type": "color",
        "$description": "Input borders, outlines"
      },
      "text": {
        "$value": "#EAF0F7",
        "$type": "color",
        "$description": "Primary text"
      },
      "text-2": {
        "$value": "#9AA7B8",
        "$type": "color",
        "$description": "Secondary text, metadata"
      },
      "text-3": {
        "$value": "#647082",
        "$type": "color",
        "$description": "Tertiary, disabled, hints"
      },
      "platinum": {
        "$value": "#C7D2DE",
        "$type": "color",
        "$description": "Chrome accents, premium marks"
      },
      "platinum-dim": { "$value": "#8996A6", "$type": "color" },
      "success": { "$value": "#34D399", "$type": "color" },
      "warning": { "$value": "#FB8C3C", "$type": "color" },
      "error": { "$value": "#FF5A52", "$type": "color" },
      "info": { "$value": "#22C0DE", "$type": "color" }
    },
    "light": {
      "bg": { "$value": "#F4F7FB", "$type": "color" },
      "surface-1": { "$value": "#FFFFFF", "$type": "color" },
      "surface-2": { "$value": "#EDF1F7", "$type": "color" },
      "surface-3": { "$value": "#E1E8F1", "$type": "color" },
      "border-subtle": { "$value": "#E4EAF2", "$type": "color" },
      "border": { "$value": "#D0D9E5", "$type": "color" },
      "text": { "$value": "#0E141F", "$type": "color" },
      "text-2": { "$value": "#4A5666", "$type": "color" },
      "text-3": { "$value": "#7C8798", "$type": "color" },
      "platinum": { "$value": "#6B7787", "$type": "color" },
      "platinum-dim": { "$value": "#9AA6B4", "$type": "color" },
      "success": { "$value": "#0E9F6E", "$type": "color" },
      "warning": { "$value": "#C2540B", "$type": "color" },
      "error": { "$value": "#DC2626", "$type": "color" },
      "info": { "$value": "#0E7C93", "$type": "color" }
    }
  },
  "accent": {
    "$description": "User-selectable. Set data-accent on <html>. 'bright' is the link/icon variant and differs per theme so it stays legible on white. Every base clears WCAG AA (4.5:1) against white button text \u2014 verified by audit.py. Check any new preset before shipping it.",
    "presets": {
      "bluray": {
        "label": "Blu-ray",
        "base": "#2A6FD6",
        "hover": "#3C7CE1",
        "press": "#2259B0",
        "bright-dark": "#6CB4FC",
        "bright-light": "#1F5FBF",
        "on": "#FFFFFF",
        "default": true,
        "$description": "Sampled from the app icon. Hover is the icon's literal core blue."
      },
      "amethyst": {
        "label": "Amethyst",
        "base": "#6D5FE6",
        "hover": "#8375EE",
        "press": "#584BC4",
        "bright-dark": "#A99BFF",
        "bright-light": "#5B4CD1",
        "on": "#FFFFFF"
      },
      "chrome": {
        "label": "Chrome",
        "base": "#6B7787",
        "hover": "#7D8998",
        "press": "#565F6C",
        "bright-dark": "#C7D2DE",
        "bright-light": "#55606E",
        "on": "#FFFFFF"
      },
      "emerald": {
        "label": "Emerald",
        "base": "#0C835B",
        "hover": "#0E8F63",
        "press": "#0A6C4B",
        "bright-dark": "#4ADCA4",
        "bright-light": "#0A6C4B",
        "on": "#FFFFFF"
      },
      "teal": {
        "label": "Teal",
        "base": "#0E7C93",
        "hover": "#1191AB",
        "press": "#0B6376",
        "bright-dark": "#46CDE4",
        "bright-light": "#0B6376",
        "on": "#FFFFFF"
      },
      "crimson": {
        "label": "Crimson",
        "base": "#D62F3C",
        "hover": "#E24450",
        "press": "#B32530",
        "bright-dark": "#FF7A82",
        "bright-light": "#B32530",
        "on": "#FFFFFF"
      },
      "magenta": {
        "label": "Magenta",
        "base": "#C93384",
        "hover": "#D94795",
        "press": "#A82A6D",
        "bright-dark": "#FF7CC0",
        "bright-light": "#A82A6D",
        "on": "#FFFFFF"
      },
      "ember": {
        "label": "Ember",
        "base": "#A76400",
        "hover": "#B26B00",
        "press": "#8A5300",
        "bright-dark": "#FFB23E",
        "bright-light": "#8A5300",
        "on": "#FFFFFF"
      }
    }
  },
  "format": {
    "$description": "Fixed. Never themed, never affected by the accent picker. Each badge borrows from the real physical object.",
    "4k": {
      "$description": "Monochrome \u2014 mirrors the black 4K keepcase with silver-white type. Inverts with theme.",
      "dark": { "fill": "#F2F6FA", "on": "#0A0E14", "line": "#FFFFFF" },
      "light": { "fill": "#12181F", "on": "#FFFFFF", "line": "#12181F" }
    },
    "bluray": {
      "$description": "The blue laser.",
      "dark": { "fill": "#3B9EFF", "on": "#04121F" },
      "light": { "fill": "#1E6FD8", "on": "#FFFFFF" }
    },
    "dvd": {
      "$description": "Oldskool \u2014 the champagne-gold dye layer on the underside of a DVD. Deliberately dated next to the cool formats.",
      "dark": { "fill": "#C2A878", "deep": "#8C7345", "on": "#1C1508" },
      "light": { "fill": "#8C7345", "deep": "#6B5730", "on": "#FFFFFF" }
    },
    "steel": {
      "$description": "Brushed metal with a raking specular highlight. The only badge with real material.",
      "dark": {
        "fill": "#8E9CAC",
        "on": "#0E141C",
        "brushed": "linear-gradient(115deg, #5C6875 0%, #8A97A6 18%, #D6E0EA 32%, #93A1B0 44%, #6B7683 58%, #B9C6D3 72%, #7E8B99 86%, #566270 100%)"
      },
      "light": {
        "fill": "#556270",
        "on": "#FFFFFF",
        "brushed": "linear-gradient(115deg, #6E7B89 0%, #9AA7B5 18%, #E2EAF2 32%, #A4B1BF 44%, #7C8996 58%, #C6D2DE 72%, #8D9AA8 86%, #67737F 100%)"
      }
    },
    "digital": {
      "$description": "No physical object, so it stays flat and synthetic.",
      "dark": { "fill": "#22C2A8", "on": "#04211C" },
      "light": { "fill": "#0E9C86", "on": "#FFFFFF" }
    }
  },
  "effect": {
    "sheen": {
      "$description": "The icon's own iridescence, unrolled into a gradient. Signature element \u2014 hero moments, loading states, premium marks. Not a background.",
      "dark": {
        "$value": "conic-gradient(from 210deg, #7EB9EB, #D6CEFA, #EDC8F0, #F9F6F6, #7EE2C6, #4C93E4, #3C7CE1, #7EB9EB)"
      },
      "light": {
        "$value": "conic-gradient(from 210deg, #5E9AD0, #B3A8E4, #D6A8DC, #E8E4EE, #5CC4A8, #3B7BC4, #2A6FD6, #5E9AD0)"
      }
    },
    "shadow": {
      "dark": {
        "$value": "0 1px 2px rgba(0,0,0,.5), 0 10px 30px rgba(0,0,0,.4)"
      },
      "light": {
        "$value": "0 1px 2px rgba(20,30,45,.06), 0 12px 32px rgba(30,60,110,.10)"
      }
    }
  },
  "pwa": {
    "$description": "Keep fixed to the neutral background \u2014 which IS the icon's background \u2014 so the splash screen and icon form one surface. Never bind these to the accent; the status bar should not flash whatever colour a user picked.",
    "theme-color-dark": { "$value": "#090F1A" },
    "theme-color-light": { "$value": "#F4F7FB" },
    "background-color": { "$value": "#090F1A" },
    "icons": {
      "$description": "Generated by icons.py from the three iOS source icons. Each platform crops differently, so the disc is rescaled per target rather than one file being resized.",
      "any": ["icon-192.png", "icon-512.png"],
      "maskable": ["icon-maskable-192.png", "icon-maskable-512.png"],
      "apple": ["apple-touch-icon-180.png"],
      "favicon": [
        "favicon.ico",
        "favicon-16.png",
        "favicon-32.png",
        "favicon-48.png"
      ],
      "android": [
        "android-ic_launcher_foreground.png",
        "android-ic_launcher_background.png",
        "android-ic_launcher_monochrome.png"
      ]
    }
  }
}
